---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPage from '../../views/AboutPage.astro';
import ServicesPage from '../../views/ServicesPage.astro';
import ApproachPage from '../../views/ApproachPage.astro';
import ContactPage from '../../views/ContactPage.astro';
import type { Lang, PageKey } from '../../data/site';

export function getStaticPaths() {
  return (['zh', 'en'] as Lang[]).flatMap((lang) =>
    (['about', 'services', 'approach', 'contact'] as PageKey[]).map((page) => ({ params: { lang, page } })),
  );
}
const lang = Astro.params.lang as Lang;
const page = Astro.params.page as PageKey;
const View = { about: AboutPage, services: ServicesPage, approach: ApproachPage, contact: ContactPage }[page];
---
<BaseLayout {lang} {page}><View {lang} /></BaseLayout>
