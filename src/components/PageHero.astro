---
interface Props { eyebrow: string; title: string; lead: string; compact?: boolean; }
const { eyebrow, title, lead, compact = false } = Astro.props;
---
<section class:list={['page-hero', compact && 'page-hero--compact']}>
  <div class="page-hero-orbit" aria-hidden="true"><i></i><i></i><i></i></div>
  <div class="page-hero-content reveal">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title.split('\n').map((line) => <>{line}<br /></>)}</h1>
    <p class="page-lead">{lead}</p>
  </div>
</section>
