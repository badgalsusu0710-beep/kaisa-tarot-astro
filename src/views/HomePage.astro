---
import type { Lang } from '../data/site';
import { getContent, localizedPath } from '../data/site';
const { lang } = Astro.props as { lang: Lang };
const c = getContent(lang);
---
<section class="home-hero">
  <canvas class="hero-starfield" data-starfield aria-hidden="true"></canvas>
  <div class="hero-nebula" aria-hidden="true"></div>
  <div class="hero-copy reveal">
    <p class="eyebrow">{c.home.eyebrow}</p>
    <h1>{c.home.title.split('\n').map((line) => <>{line}<br /></>)}</h1>
    <p class="hero-intro">{c.home.intro}</p>
    <div class="hero-actions">
      <button class="button button--gold" type="button" data-open-wechat>{c.common.book}</button>
      <a class="text-link" href={localizedPath(lang, 'services')}>{c.common.viewServices}<span>↗</span></a>
    </div>
  </div>
  <div class="hero-proof reveal">
    <p class="hero-proof-title">{c.home.proofTitle}</p>
    {c.home.proof.map((item, index) => <div><span>0{index + 1}</span><p>{item}</p></div>)}
  </div>
</section>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-starfield]');

  if (canvas) {
    const context = canvas.getContext('2d');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const pointer = { x: 0, y: 0 };
    const colors = ['205, 218, 255', '232, 235, 255', '255, 245, 225'];
    let width = 0;
    let height = 0;
    let frame = 0;
    let stars: Array<{ x: number; y: number; depth: number; size: number; alpha: number; color: string; phase: number; speed: number }> = [];

    const gaussian = () => {
      const a = Math.max(Math.random(), .0001);
      return Math.sqrt(-2 * Math.log(a)) * Math.cos(Math.PI * 2 * Math.random());
    };

    const makeStar = () => {
      const inMilkyWay = Math.random() < .72;
      const x = Math.random();
      const y = inMilkyWay
        ? .76 - x * .56 + gaussian() * .13
        : Math.random();
      const bright = Math.pow(Math.random(), 6);
      return {
        x,
        y: Math.max(-.08, Math.min(1.08, y)),
        depth: Math.random(),
        size: .24 + bright * 1.7,
        alpha: .1 + bright * .72 + Math.random() * .12,
        color: colors[Math.floor(Math.random() * colors.length)],
        phase: Math.random() * Math.PI * 2,
        speed: .12 + Math.random() * .3,
      };
    };

    const populate = () => {
      const count = width < 600 ? 190 : width < 1000 ? 280 : 390;
      stars = Array.from({ length: count }, makeStar);
    };

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const ratio = Math.min(window.devicePixelRatio || 1, 2);
      width = rect.width;
      height = rect.height;
      canvas.width = Math.round(width * ratio);
      canvas.height = Math.round(height * ratio);
      context?.setTransform(ratio, 0, 0, ratio, 0, 0);
      populate();
    };

    const drawNebula = () => {
      if (!context) return;
      context.save();
      context.translate(width * .69, height * .47);
      context.rotate(-.34);
      context.scale(1.8, .48);
      const haze = context.createRadialGradient(0, 0, 0, 0, 0, width * .34);
      haze.addColorStop(0, 'rgba(121, 115, 144, .13)');
      haze.addColorStop(.28, 'rgba(69, 65, 88, .08)');
      haze.addColorStop(1, 'rgba(8, 9, 13, 0)');
      context.fillStyle = haze;
      context.fillRect(-width, -height, width * 2, height * 2);
      context.restore();
    };

    const draw = (time = 0) => {
      if (!context) return;
      context.clearRect(0, 0, width, height);
      drawNebula();

      for (const star of stars) {
        const parallax = .25 + star.depth * .75;
        const x = star.x * width + pointer.x * 8 * parallax;
        const y = star.y * height + pointer.y * 5 * parallax;
        const twinkle = reduceMotion ? 1 : .88 + Math.sin(time * .001 * star.speed + star.phase) * .12;
        const radius = star.size * (.68 + star.depth * .5);
        const alpha = Math.min(star.alpha * twinkle, .92);

        if (radius > 1.25) {
          const glow = context.createRadialGradient(x, y, 0, x, y, radius * 4.5);
          glow.addColorStop(0, `rgba(${star.color}, ${alpha * .42})`);
          glow.addColorStop(1, `rgba(${star.color}, 0)`);
          context.fillStyle = glow;
          context.beginPath();
          context.arc(x, y, radius * 4.5, 0, Math.PI * 2);
          context.fill();
        }

        context.fillStyle = `rgba(${star.color}, ${alpha})`;
        context.beginPath();
        context.arc(x, y, radius, 0, Math.PI * 2);
        context.fill();
      }

      if (!reduceMotion) frame = window.requestAnimationFrame(draw);
    };

    const onPointerMove = (event: PointerEvent) => {
      pointer.x = event.clientX / window.innerWidth - .5;
      pointer.y = event.clientY / window.innerHeight - .5;
    };

    resize();
    draw();
    window.addEventListener('resize', resize, { passive: true });
    window.addEventListener('pointermove', onPointerMove, { passive: true });
    window.addEventListener('pagehide', () => window.cancelAnimationFrame(frame), { once: true });
  }
</script>

<section class="section section--services">
  <div class="section-heading reveal"><p class="eyebrow">{c.home.servicesEyebrow}</p><h2>{c.home.servicesTitle}</h2><p>{c.home.servicesIntro}</p></div>
  <div class="service-preview-grid">
    {c.home.serviceCards.map((card) => <a class="service-preview reveal" href={card.link}><span class="service-icon">{card.icon}</span><div><small>{card.en}</small><h3>{card.title}</h3><p>{card.text}</p></div><span class="arrow">↗</span></a>)}
  </div>
</section>

<section class="spread-carousel-section">
  <div class="spread-carousel-heading reveal">
    <p class="eyebrow">{c.spreads.eyebrow}</p>
    <h2>选择适合你的牌阵</h2>
    <p>左右滑动查看结构、牌数与适用问题。</p>
  </div>
  <div class="spread-carousel reveal" aria-label="牌阵横向滑动列表">
    {c.spreads.items.map((spread, index) => (
      <article class="spread-preview-card">
        <div class="spread-preview-head">
          <p>0{index + 1} · {spread.cards}</p>
          <h3>{spread.name}</h3>
          <span>{spread.en}</span>
        </div>
        <div class="spread-preview-stage">
          <svg viewBox={`0 0 600 ${spread.vh}`} role="img" aria-label={spread.name}>
            <g class="spread-preview-links">{spread.links.map((line) => <line x1={line[0]} y1={line[1]} x2={line[2]} y2={line[3]} />)}</g>
            {spread.layout.map((point, cardIndex) => (
              <g class="spread-preview-mini-card">
                <rect x={point[0] - spread.cw / 2} y={point[1] - spread.ch / 2} width={spread.cw} height={spread.ch} rx="10" />
                <text x={point[0]} y={point[1]}>{cardIndex + 1}</text>
              </g>
            ))}
          </svg>
        </div>
        <p class="spread-preview-text">{spread.suitable}</p>
      </article>
    ))}
  </div>
</section>

<section class="visual-journal">
  <div class="visual-journal-heading reveal">
    <p class="eyebrow">{c.home.journalEyebrow}</p>
    <h2>{c.home.journalTitle}</h2>
  </div>
  <div class="visual-journal-grid">
    <figure class="journal-image journal-image--tall reveal"><img src="/images/media/tarot-city.webp" alt={c.home.journalItems[0]} loading="lazy" width="1200" height="1600" /><figcaption>{c.home.journalItems[0]}</figcaption></figure>
    <figure class="journal-image reveal"><img src="/images/media/practice-astrology.webp" alt={c.home.journalItems[1]} loading="lazy" width="1050" height="1400" /><figcaption>{c.home.journalItems[1]}</figcaption></figure>
    <figure class="journal-image journal-image--wide reveal"><img src="/images/media/practice-ocean.webp" alt={c.home.journalItems[2]} loading="lazy" width="1200" height="1600" /><figcaption>{c.home.journalItems[2]}</figcaption></figure>
  </div>
</section>

<section class="section feedback-section">
  <div class="section-heading reveal"><p class="eyebrow">CLIENT FEEDBACK</p><h2>{c.approach.caseTitle}</h2></div>
  <div class="feedback-grid">
    {c.approach.cases.map((item) => <article class="fb-frame reveal"><p class="fb-who">{item.who}</p><div class="fb-thread">{item.msgs.map((msg) => <div class="fb-row"><span class="fb-av" aria-hidden="true"></span><p class="fb-bubble">{msg}</p></div>)}</div></article>)}
  </div>
  <p class="privacy-note">✦ {c.approach.privacy}</p>
</section>

<section class="quote-section reveal">
  <div class="quote-symbol">“</div><blockquote>{c.home.quote}</blockquote><p>{c.home.quoteMeta}</p>
</section>

<section class="closing-cta">
  <div class="closing-glow" aria-hidden="true"></div>
  <div class="closing-copy reveal">
    <p class="eyebrow">PRIVATE CONSULTATION</p>
    <h2>从一个真实的问题开始，<br />慢慢看见答案。</h2>
    <p>添加微信后，简单说明你的问题与背景。我会帮你确认适合的咨询方式，再安排后续预约。</p>
  </div>
  <aside class="booking-card reveal" aria-label="微信预约二维码">
    <p>SCAN TO BOOK</p>
    <img src="/images/media/wechat-qr.png" alt="微信预约二维码" width="502" height="502" loading="lazy" />
    <h3>微信预约咨询</h3>
    <span>扫描二维码，或搜索微信号</span>
    <strong>KaisaTarot</strong>
  </aside>
</section>
